generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  scans     Scan[]
  siteScans SiteScan[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/**
 * ===================== Domínio: histórico de scans =====================
 */

model Scan {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  url      String
  finalUrl String
  title    String
  score    Int

  critical Int
  serious  Int
  moderate Int
  minor    Int
  passed   Int

  durationMs Int

  result Json

  createdAt DateTime @default(now())

  screenshot Screenshot?

  @@index([userId, createdAt])
  @@index([userId, url, createdAt])
  @@map("scans")
}

model Screenshot {
  scanId   String @id
  scan     Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
  data     Bytes // JPEG comprimido (~80KB)
  mimeType String @default("image/jpeg")

  @@map("screenshots")
}

/**
 * ===================== Domínio: crawl multi-página =====================
 * Job durável que audita várias páginas de um site. Cada página vira uma
 * invocação curta (via QStash) que grava seu resultado aqui; o front faz
 * polling do progresso. userId é nullable — o crawl funciona anônimo.
 */

model SiteScan {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rootUrl String
  status  String @default("running") // running | completed | failed

  totalPages   Int @default(0)
  scannedPages Int @default(0)
  failedPages  Int @default(0)

  score Int? // média dos scores das páginas concluídas
  error String?

  pages SiteScanPage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@map("site_scans")
}

model SiteScanPage {
  id         String   @id @default(cuid())
  siteScanId String
  siteScan   SiteScan @relation(fields: [siteScanId], references: [id], onDelete: Cascade)

  url    String
  status String @default("pending") // pending | running | done | failed

  title String?
  score Int?

  critical Int @default(0)
  serious  Int @default(0)
  moderate Int @default(0)
  minor    Int @default(0)

  error String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteScanId])
  @@map("site_scan_pages")
}
